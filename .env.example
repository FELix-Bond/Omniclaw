# =============================================================================
# OmniClaw Environment Template
# Copy to .env and fill in your values.
# NEVER commit .env to GitHub.
# =============================================================================

# Company Identity
COMPANY_NAME="OmniGen_Systems"
OWNER_NAME="Felix"
MISSION="Automate cross-platform intelligence and executive decision-making."
TIMEZONE="Australia/Sydney"

# Schedule
HEARTBEAT_INTERVAL="15m"   # 5m / 15m / 30m / 1h
BUDGET_LIMIT="$50"

# Infrastructure
DASHBOARD_PORT=3000
VAULT_PATH="/Users/yourname/Documents/Vault"
PROJECT_ROOT="~/omniclaw"
NEMOCLAW_RUNTIME="openshell-v4"
INFERENCE_ENGINE="turboquant-int4"
CLOUD_MODEL="claude-sonnet-4-6"

# Decision Engine
DECISION_MODE="full"          # rapid / full / deep
ESCALATION_THRESHOLD="$10,000"
AUTO_OPEN_DASHBOARD="true"

# GitHub
GITHUB_USER="your-github-username"
GITHUB_REPO="omniclaw-bootstrap"
REPO_VISIBILITY="private"

# =============================================================================
# API Keys — Fill these in
# =============================================================================
ANTHROPIC_API_KEY=""
PAPERCLIP_API_KEY=""
FIRECRAWL_API_KEY=""
SKILLSMP_API_KEY=""

# Communication
TG_TOKEN=""
TG_CHAT_ID=""
DISCORD_TOKEN=""
DISCORD_CHANNEL_ID=""

# Data
SUPABASE_URL=""
SUPABASE_KEY=""
GOOGLE_DOCS_FOLDER_ID=""
